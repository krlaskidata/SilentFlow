@page
@model IndexModel

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>QuietStream</title>

    <style>
        body {
            margin: 0;
            background: #0f172a;
            color: white;
            font-family: Arial;
        }

        /* 🔝 NAVBAR */
        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            display: flex;
            justify-content: center;
            gap: 40px;
            padding: 15px;
            background: rgba(15, 23, 42, 0.9);
        }

        .navbar a {
            color: #cbd5f5;
            text-decoration: none;
            font-weight: bold;
        }

        .navbar a:hover {
            color: white;
        }

        /* 📦 CENTERED CONTENT */
        .main {
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            background: #1e293b;
            padding: 30px;
            border-radius: 14px;
            width: 420px;
            box-shadow: 0 0 40px rgba(0,0,0,0.6);
        }

        h2 {
            text-align: center;
        }

        input, select, button {
            width: 100%;
            margin-top: 12px;
            padding: 10px;
            border-radius: 8px;
            border: none;
        }

        input, select {
            background: #334155;
            color: white;
        }

        button {
            background: #4f46e5;
            color: white;
            font-weight: bold;
            cursor: pointer;
        }

        button:hover {
            background: #4338ca;
        }

        .result {
            margin-top: 15px;
            color: #22c55e;
        }

        .error {
            margin-top: 15px;
            color: #ef4444;
        }

        /* 🔒 MODAL */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: #1e293b;
            padding: 25px;
            border-radius: 12px;
            width: 400px;
        }

        .close {
            float: right;
            cursor: pointer;
        }
    </style>

    <script>
        function openPrivacy() {
            document.getElementById("privacyModal").style.display = "flex";
        }

        function closePrivacy() {
            document.getElementById("privacyModal").style.display = "none";
        }
    </script>

</head>

<body>

    <!-- ✅ NAVBAR FIXED -->
    <div class="navbar">
        <a href="/">Home</a>
        <a href="#" onclick="openPrivacy()">Privacy</a>
    </div>

    <!-- ✅ CENTER -->
    <div class="main">
        <div class="container">
            <h2>🎧 QuietStream</h2>

            <form method="post">
                <input asp-for="Url" placeholder="Video URL einfügen..." />

                <select asp-for="Format">
                    <option value="mp4">MP4 (Video)</option>
                    <option value="mp3">MP3 (Audio)</option>
                </select>

                <button type="submit">Convert</button>
            </form>

            @if (!string.IsNullOrEmpty(Model.Result))
            {
                <div class="result">@Model.Result</div>
            }

            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="error">@Model.Error</div>
            }
        </div>
    </div>

    <!-- ✅ PRIVACY MODAL -->
    <div id="privacyModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closePrivacy()">✖</span>
            <h3>🔒 Datenschutz</h3>
            <p>
                Diese Anwendung läuft vollständig lokal auf deinem Gerät.<br><br>
                Es werden keine Daten gespeichert, kein Tracking durchgeführt und keine Werbung angezeigt.<br><br>
                Downloads erfolgen direkt zwischen deinem Gerät und der Plattform.
            </p>
        </div>
    </div>

</body>
</html>

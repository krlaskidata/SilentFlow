@page
@model IndexModel

<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<title>SilentFlow</title>

<style>
body {
    margin: 0;
    background: #0f172a;
    font-family: Arial;
}

/* ✅ HEADER */
.header {
    background: white;
    height: 80px;
    display: flex;
    justify-content: center;
    align-items: center;
}

.title {
    font-size: 32px;
    font-weight: bold;
    color: black;
}

/* ✅ MAIN */
.main {
    height: calc(100vh - 80px);
    display: flex;
    justify-content: center;
    align-items: center;
}

.container {
    width: 320px;
}

input, select, button {
    width: 100%;
    margin-top: 12px;
    padding: 10px;
    border-radius: 6px;
    border: none;
}

input, select {
    background: #1e293b;
    color: white;
}

button {
    background: #4f46e5;
    color: white;
    font-weight: bold;
    cursor: pointer;
}

/* ✅ PROGRESSBAR */
.progress-container {
    margin-top: 15px;
    width: 100%;
    border: 2px solid white;
    border-radius: 6px;
    height: 25px;
}

.progress-bar {
    height: 100%;
    width: 0%;
    background: #22c55e;
    text-align: center;
    color: black;
    font-weight: bold;
}

/* ✅ TEXT */
.result {
    margin-top: 15px;
    color: #22c55e;
}

.error {
    margin-top: 15px;
    color: #ef4444;
}
</style>

<script>
let interval;

function startProgress() {
    let bar = document.getElementById("progressBar");

    interval = setInterval(async () => {
        const res = await fetch("/?handler=Progress");
        const percent = await res.json();

        bar.style.width = percent + "%";
        bar.innerText = percent + "%";

        if (percent >= 100) {
            clearInterval(interval);
        }
    }, 500);
}
</script>

</head>

<body>

<!-- ✅ HEADER -->
<div class="header">
    <div class="title">SilentFlow</div>
</div>

<!-- ✅ MAIN -->
<div class="main">
<div class="container">

    <!-- ✅ DAS ist die richtige Stelle für onsubmit -->
    <form method="post" onsubmit="startProgress()">
        <input asp-for="Url" placeholder="Video URL einfügen..." />

        <select asp-for="Format">
            <option value="mp4">MP4</option>
            <option value="mp3">MP3</option>
        </select>

        <button type="submit">Convert</button>
    </form>

    <!-- ✅ PROGRESSBAR -->
    <div class="progress-container">
        <div class="progress-bar" id="progressBar">0%</div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Result))
    {
        <div class="result">@Model.Result</div>
    }

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="error">@Model.Error</div>
    }

</div>
</div>

</body>
</html>
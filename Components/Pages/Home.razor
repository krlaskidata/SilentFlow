@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@inject DownloadService DownloadService
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>SilentFlow</PageTitle>

<div class="main">
    <DownloadContainer ClientIp="@_clientIp" Placeholder="YouTube, Instagram, Facebook, TikTok URL..." @ref="_container1" />
    <DownloadContainer ClientIp="@_clientIp" Placeholder="Externen URL eingeben..." @ref="_container2" />

    <div class="update-bar">
        <button class="btn-update" @onclick="ResetAll">Zurücksetzen</button>
        <button class="btn-update" @onclick="UpdateYtDlp" disabled="@isUpdating">
            @(isUpdating ? "Aktualisiert..." : "yt-dlp aktualisieren")
        </button>
        @if (!string.IsNullOrEmpty(updateMessage))
        {
            <span class="update-msg">@updateMessage</span>
        }
    </div>
</div>

@code {
    private string _clientIp = "unknown";
    private bool isUpdating;
    private string updateMessage = string.Empty;

    private DownloadContainer _container1 = default!;
    private DownloadContainer _container2 = default!;

    protected override void OnInitialized()
    {
        var ip = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString();
        if (!string.IsNullOrEmpty(ip))
            _clientIp = ip;
    }

    private async Task UpdateYtDlp()
    {
        isUpdating = true;
        updateMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        updateMessage = await DownloadService.UpdateYtDlpAsync();
        isUpdating = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ResetAll()
    {
        await Task.WhenAll(_container1.ResetAsync(), _container2.ResetAsync());
        updateMessage = string.Empty;
        await InvokeAsync(StateHasChanged);
    }
}

